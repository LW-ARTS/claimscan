        {
          "type": "frame",
          "id": "qjlBr",
          "name": "Terms Section",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 40,
          "padding": [
            0,
            200
          ],
          "children": [
            {
              "type": "frame",
              "id": "qmtIf",
              "name": "Section 1",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "gKrwa",
                  "fill": "$--text-primary",
                  "content": "1. ACCEPTANCE OF TERMS",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "MRHuR",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "By accessing and using ClaimScan ('the Service'), you acknowledge that you have read, understood, and agree to be bound by these Terms of Service. If you do not agree with any part of these terms, you must discontinue use of the Service immediately. These terms apply to all users, including visitors, registered users, and API consumers.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15
                }
              ]
            },
            {
              "type": "frame",
              "id": "xOeWB",
              "name": "Section 2",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "eAfMR",
                  "fill": "$--text-primary",
                  "content": "2. DESCRIPTION OF SERVICE",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "qXPjO",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "ClaimScan provides a fee tracking and discovery platform for cryptocurrency creators. The Service scans supported launchpad platforms across multiple blockchain networks to identify unclaimed creator fees. ClaimScan does not custody, hold, or manage any funds. All claim transactions are executed directly on-chain through the respective platform smart contracts.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15
                }
              ]
            },
            {
              "type": "frame",
              "id": "OytnA",
              "name": "Section 3",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "a8wqd",
                  "fill": "$--text-primary",
                  "content": "3. SUPPORTED PLATFORMS & CHAINS",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "YMUeU",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Service currently supports fee tracking across pump.fun, Raydium, Clanker, Believe, Zora, Bags, Bankr, Coinbarrel, RevShare, and Virtuals on Solana, Base, Ethereum, and BSC networks. Platform availability may change without prior notice. ClaimScan makes no guarantees regarding the accuracy, completeness, or timeliness of fee data from third-party platforms.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15
                }
              ]
            },
            {
              "type": "frame",
              "id": "OR8Tz",
              "name": "Section 4",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "r3Zvq",
                  "fill": "$--text-primary",
                  "content": "4. USER RESPONSIBILITIES",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "x7sfZ",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "You are solely responsible for the security of your wallet and private keys. ClaimScan will never request your private keys or seed phrases. You acknowledge that blockchain transactions are irreversible. You agree not to use the Service for any unlawful purpose or in violation of any applicable regulations in your jurisdiction.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15
                }
              ]
            },
            {
              "type": "frame",
              "id": "0to2e",
              "name": "Section 5",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "EsQdB",
                  "fill": "$--text-primary",
                  "content": "5. API USAGE",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "Wp2Sk",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Access to the ClaimScan API is subject to rate limiting based on your subscription tier. API keys are non-transferable and must not be shared publicly. Abuse of the API, including excessive requests, scraping, or redistribution of data without permission, may result in immediate suspension of access without refund.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15
                }
              ]
            },
            {
              "type": "frame",
              "id": "N6Nfg",
              "name": "Section 6",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "Nr6gK",
                  "fill": "$--text-primary",
                  "content": "6. LIMITATION OF LIABILITY",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "hihG4",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "ClaimScan is provided 'as is' without warranty of any kind. We shall not be liable for any direct, indirect, incidental, or consequential damages arising from the use of this Service. This includes but is not limited to loss of funds, failed transactions, inaccurate fee data, or service interruptions. Use the Service at your own risk.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15
                }
              ]
            },
            {
              "type": "frame",
              "id": "kEkun",
              "name": "Section 7",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "KMXWK",
                  "fill": "$--text-primary",
                  "content": "7. MODIFICATIONS",
                  "fontFamily": "Inter",
                  "fontSize": 22,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "ceryJ",
                  "fill": "$--text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We reserve the right to modify these Terms at any time. Changes will be posted on this page with an updated effective date. Continued use of the Service after changes constitutes acceptance of the revised Terms. Last updated: April 4, 2026.",
