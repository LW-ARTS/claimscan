# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RPC Endpoints
SOLANA_RPC_URL=https://your-solana-rpc-provider.com/YOUR_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=https://your-solana-rpc-provider.com/YOUR_KEY
BASE_RPC_URL=https://your-base-rpc-provider.com/YOUR_KEY

# Platform API Keys
BAGS_API_KEY=
ZORA_API_KEY=

# Helius (DAS API, Enhanced Transactions, Webhooks)
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=your-webhook-auth-secret

# Cron Auth
CRON_SECRET=your-cron-secret

# Claim HMAC (optional — falls back to CRON_SECRET if not set)
# Recommended: set a dedicated secret to isolate claim auth from cron auth
CLAIM_HMAC_SECRET=
