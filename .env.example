# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RPC Endpoints
SOLANA_RPC_URL=https://your-solana-rpc-provider.com/YOUR_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=https://your-solana-rpc-provider.com/YOUR_KEY
BASE_RPC_URL=https://your-base-rpc-provider.com/YOUR_KEY
# Optional — Ethereum mainnet RPC for ERC-20 fee reads (Clanker Ethereum, etc).
# Falls back to public RPCs if not set (not recommended for production).
ETH_RPC_URL=https://your-eth-rpc-provider.com/YOUR_KEY
# Required for BSC chain support (Clanker BSC, etc). Public RPCs are unreliable.
BSC_RPC_URL=https://your-bsc-rpc-provider.com/YOUR_KEY

# Platform API Keys
# Legacy single key — superseded by BAGS_API_KEYS for multi-key rotation.
BAGS_API_KEY=
# Comma-separated list of Bags.fm API keys (rotated round-robin to avoid rate limits).
BAGS_API_KEYS=
ZORA_API_KEY=
# Bankr platform API key (used by lib/platforms/bankr.ts adapter)
BANKR_API_KEY=
# Bankr bearer token — preferred when set, falls back to BANKR_API_KEY (x-api-key header)
# Used by lib/platforms/bankr.ts for authenticated fee-history endpoints
BANKR_BEARER_TOKEN=
# Bankr API base URL override (default: https://api.bankr.bot)
# Only set if Bankr provides a tenant-specific endpoint
BANKR_API_URL=
# Neynar Farcaster API key (alternative to public Farcaster Hub for identity resolution)
NEYNAR_API_KEY=

# Flaunch (Base mainnet, https://flaunch.gg)
# Optional. Default is embedded in lib/flaunch/client.ts.
# Override only for testing against Flaunch's staging or a local proxy.
FLAUNCH_API_BASE=https://dev-api.flayerlabs.xyz

# Helius (DAS API, Enhanced Transactions, Webhooks)
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=your-webhook-auth-secret

# Cron Auth
CRON_SECRET=your-cron-secret

# Claim HMAC (required in production — min 32 chars)
# Generate with: openssl rand -hex 32
CLAIM_HMAC_SECRET=

# Upstash Redis (optional — enables persistent rate limiting across serverless instances)
# Free tier: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (optional — enables CAPTCHA on /api/search)
# Free: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CoinGecko Demo API Key (recommended — guarantees 30 req/min vs ~10 without)
# Free: https://www.coingecko.com/en/api/pricing (Demo plan)
COINGECKO_API_KEY=

# Jupiter API Key (optional — higher rate limits on Jupiter price API)
# Get one at: https://portal.jup.ag
JUP_API_KEY=

# App URL (used for CORS, sitemap, robots — defaults to https://claimscan.tech)
NEXT_PUBLIC_APP_URL=https://claimscan.tech

# Farcaster Hub (optional — defaults to hub.pinata.cloud)
# FARCASTER_HUB_URL=https://hub.pinata.cloud/v1
# WARPCAST_API_URL=https://client.warpcast.com/v2

# Sentry (optional — error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only (Vercel production). Used by withSentryConfig in next.config.ts
# to create releases and upload source maps so prod stack traces show original
# .ts filenames instead of minified chunks. NOT needed for local dev.
SENTRY_ORG=                    # 'lw-52' for production
SENTRY_PROJECT=                # 'claimscan' for production
SENTRY_AUTH_TOKEN=             # Personal token from https://lw-52.sentry.io/settings/account/api/auth-tokens/
                               # Required scopes: org:read, project:read, project:releases

# Request Signing (optional — prevents casual API scraping with curl/python)
# Generate with: openssl rand -hex 32
NEXT_PUBLIC_API_SIGN_KEY=

# Resolve Pipeline (optional — override for external deploys)
# Default: 55000ms (55s). Vercel Hobby has 60s max, so 55s leaves margin.
RESOLVE_TIMEOUT_MS=

# ── x402 Protocol (V2 paid API endpoints) ──
# EVM address to receive USDC payments (required for /api/v2/* endpoints)
X402_WALLET_ADDRESS=
# Network for x402 settlement (default: eip155:84532 Base Sepolia)
# Use eip155:8453 for Base mainnet
X402_NETWORK=eip155:84532
# Facilitator URL (default: https://x402.org/facilitator)
X402_FACILITATOR_URL=

# ── Allium (onchain intelligence enrichment) ──
# API key for Allium wallet data (transactions, PnL)
# Get one at: https://www.allium.so
ALLIUM_API_KEY=
